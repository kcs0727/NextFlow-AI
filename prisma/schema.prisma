datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String        @id @default(uuid())
  clerkId        String        @unique
  email          String        @unique
  name           String?
  image          String?
  isPremium      Boolean       @default(false)
  freeUsageCount Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  creations      Creation[]
  workflows      Workflow[]

  @@index([clerkId])
}

model Creation {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  prompt    String
  content   String
  type      String
  publish   Boolean  @default(false)
  likes     String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([publish])
  @@index([type])
}

model Workflow {
  id        String        @id @default(cuid())
  name      String
  userId    String
  user      User          @relation(fields: [userId], references: [clerkId], onDelete: Cascade)
  graphJson Json
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  runs      WorkflowRun[]

  @@index([userId, updatedAt])
}

model WorkflowRun {
  id          String    @id @default(cuid())
  workflowId  String?
  workflow    Workflow?  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  userId      String
  scope       String
  status      String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  selectedIds Json?
  nodeRuns    NodeRun[]

  @@index([userId, startedAt])
  @@index([workflowId])
}

model NodeRun {
  id         String      @id @default(cuid())
  runId      String
  run        WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId     String
  nodeType   String
  status     String
  inputJson  Json?
  outputJson Json?
  error      String?
  durationMs Int?

  @@index([runId])
  @@index([nodeId])
}
